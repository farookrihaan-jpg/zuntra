# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/pinvault
# Atlas (replace with your connection string):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/pinvault?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Client ───────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
